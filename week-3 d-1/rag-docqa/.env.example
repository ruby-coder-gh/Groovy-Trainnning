# ─────────────────────────────────────────────────────────────────────
# RAG Doc-Q&A v2 — Environment Configuration
# ─────────────────────────────────────────────────────────────────────

## OpenAI — used for embeddings (text-embedding-3-small) and LLM answering
OPENAI_API_KEY=sk-your-openai-api-key

## Anthropic — alternative LLM provider (set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

## LLM Provider Selection
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai

## LLM Model
# For openai:  gpt-4o-mini (default), gpt-4o, etc.
# For anthropic: claude-sonnet-4-20250514, claude-haiku-3-5, etc.
# For ollama:  qwen3:8b (default), llama3.2, etc.
LLM_MODEL=gpt-4o-mini

## Embedding Provider
# Options: openai (default, requires API key) | ollama (free/local, requires Ollama running)
EMBEDDING_PROVIDER=openai

## Ollama Embedding Model (only used when EMBEDDING_PROVIDER=ollama)
# nomic-embed-text (768-d), mxbai-embed-large (1024-d), all-minilm (384-d)
OLLAMA_EMBED_MODEL=nomic-embed-text

## Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

## Chunking Configuration
CHUNK_SIZE=500       # Target tokens per chunk (default: 500)
CHUNK_OVERLAP=50     # Token overlap between chunks (default: 50)

## Retrieval
TOP_K=3              # Number of chunks to retrieve per query (default: 3)

## Server
PORT=3001            # Express server port (default: 3001)

## Vector Store
# ChromaDB persistence directory (default: ./data/chroma)
CHROMA_PERSIST_DIR=./data/chroma
