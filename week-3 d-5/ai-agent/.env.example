# ─────────────────────────────────────────────────────────────────
# Groovy AI Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The agent reads these from the environment at runtime.

# REQUIRED: Google Gemini API key (free)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Gemini model (optional, default: gemini-2.0-flash)
# GEMINI_MODEL="gemini-2.0-flash"

# OPTIONAL: Slack incoming webhook URL
# Create one at https://api.slack.com/messaging/webhooks
# If not set, the agent will still work (just won't post to Slack)
SLACK_WEBHOOK_URL=""

# OPTIONAL: GitHub personal access token (for private repos / higher rate limits)
# Public repos work without this.
# GITHUB_TOKEN=""
